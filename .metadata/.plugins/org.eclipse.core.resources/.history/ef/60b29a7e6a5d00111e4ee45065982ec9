<%@ page contentType="text/html;charset=UTF-8" %>
<html>
<head>
    <title>Edit Employee</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>

<div class="form-container">
    <h2>Edit Employee</h2>

    <form action="employee?action=update" method="post">
        <input type="hidden" name="id" value="${employee.id}">
        <input type="text" name="name" value="${employee.name}" required>
        <input type="email" name="email" value="${employee.email}" required>
        <input type="text" name="department" value="${employee.department}" required>
        <input type="number" step="0.01" name="salary" value="${employee.salary}" required>
        <button type="submit">Update Employee</button>
    </form>

    <p><a href="employee?action=list">Back to Dashboard</a></p>
</div>

</body>
</html>